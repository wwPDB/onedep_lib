{
  "$schemas": "http://json-schema.org/draft/2020-12/schema",
  "$id": "files.json",
  "title": "filecheck",
  "description": "schema for validation of input files for pdb deposition",
  "type": "object",
  "properties": {
    "method": {
      "enum": [
        "xray",
        "fiber",
        "neutron",
        "em",
        "ec",
        "nmr",
        "ssnmr"
      ],
      "feedback": {
        "enum": "unknown method"
      }
    },
    "subtype": {
      "enum": [
        "single",
        "helical",
        "tomography",
        "subtomogram"
      ],
      "feedback": {
        "enum": "unknown subtype"
      }
    },
    "files": {
      "type": "array",
      "items": {
        "enum": [
          "co-pdb",
          "co-cif",
          "xs-cif",
          "xs-mtz",
          "xa-par",
          "xa-top",
          "xa-mat",
          "layer-lines",
          "vo-map",
          "img-emdb",
          "add-map",
          "mask-map",
          "half-map",
          "fsc-xml",
          "nm-shi",
          "nm-res-amb",
          "nm-aux-amb",
          "nm-res-ari",
          "nm-res-bio",
          "nm-aux-cha",
          "nm-res-cha",
          "nm-res-cns",
          "nm-res-cya",
          "nm-res-dyn",
          "nm-res-gro",
          "nm-aux-gro",
          "nm-res-isd",
          "nm-res-ros",
          "nm-res-sch",
          "nm-res-syb",
          "nm-res-xpl",
          "nm-res-oth",
          "nm-pea-any",
          "nm-uni-nef",
          "nm-uni-str"
        ],
        "feedback": {
          "enum": "unknown file type"
        }
      }
    }
  },
  "required": [
    "method",
    "files"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "method": {
            "const": "xray"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "allOf": [
              {
                "contains": {
                  "const": "co-cif"
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "one coordinates file is required for xray",
                  "minContains": "only one coordinates file is allowed for xray",
                  "maxContains": "only one coordinates file is allowed for xray"
                }
              },
              {
                "contains": {
                  "enum": [
                    "xs-cif",
                    "xs-mtz"
                  ]
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "one reflections file is required for xray",
                  "minContains": "only one reflections file is allowed for xray",
                  "maxContains": "only one reflections file is allowed for xray"
                }
              }
            ],
            "items": {
              "enum": [
                "co-cif",
                "xs-cif",
                "xs-mtz",
                "xa-par",
                "xa-top",
                "xa-mat"
              ],
              "feedback": {
                "enum": "unknown file type for xray diffraction"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "neutron"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "allOf": [
              {
                "contains": {
                  "enum": [
                    "co-cif",
                    "co-pdb"
                  ]
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "one coordinates file is required for neutron",
                  "minContains": "only one coordinates file is allowed for neutron",
                  "maxContains": "only one coordinates file is allowed for neutron"
                }
              },
              {
                "contains": {
                  "enum": [
                    "xs-cif",
                    "xs-mtz"
                  ]
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "one reflections file is required for neutron",
                  "minContains": "only one reflections file is allowed for fiber",
                  "maxContains": "only one reflections file is allowed for fiber"
                }
              }
            ],
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "xs-cif",
                "xs-mtz",
                "xa-par",
                "xa-top",
                "xa-mat"
              ],
              "feedback": {
                "enum": "unknown file type for neutron diffraction"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "fiber"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "allOf": [
              {
                "contains": {
                  "enum": [
                    "co-pdb",
                    "co-cif"
                  ]
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "one coordinates file is required for fiber",
                  "minContains": "only one coordinates file is allowed for fiber",
                  "maxContains": "only one coordinates file is allowed for fiber"
                }
              },
              {
                "contains": {
                  "enum": [
                    "xs-cif",
                    "xs-mtz"
                  ]
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "one reflections file is required for fiber",
                  "minContains": "only one reflections file is allowed for fiber",
                  "maxContains": "only one reflections file is allowed for fiber"
                }
              }
            ],
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "layer-lines",
                "xs-cif",
                "xs-mtz",
                "xa-par",
                "xa-top",
                "xa-mat"
              ],
              "feedback": {
                "enum": "unknown file type for fiber diffraction"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "em"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "allOf": [
              {
                "contains": {
                  "const": "img-emdb"
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "an img-emdb file is required for em",
                  "minContains": "only one img-emdb file is allowed",
                  "maxContains": "only one img-emdb file is allowed"
                }
              },
              {
                "contains": {
                  "const": "vo-map"
                },
                "minContains": 1,
                "maxContains": 1,
                "feedback": {
                  "contains": "a map file is required for em",
                  "minContains": "only one map file is allowed for em",
                  "maxContains": "only one map file is allowed for em"
                }
              },
              {
                "contains": {
                  "enum": [
                    "xs-cif",
                    "xs-mtz"
                  ]
                },
                "minContains": 0,
                "maxContains": 1,
                "feedback": {
                  "contains": "one of reflections file is required for em",
                  "maxContains": "only one reflections file is allowed for em"
                }
              }
            ],
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "vo-map",
                "img-emdb",
                "add-map",
                "mask-map",
                "half-map",
                "fsc-xml",
                "layer-lines",
                "xs-cif",
                "xs-mtz"
              ],
              "feedback": {
                "enum": "unknown file type for em"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "em"
          }
        }
      },
      "then": {
        "required": [
          "subtype"
        ],
        "feedback": {
          "required": "subtype is required for em"
        }
      }
    },
    {
      "if": {
        "properties": {
          "subtype": {
            "enum": [
              "single",
              "helical",
              "subtomogram"
            ]
          }
        },
        "required": [
          "subtype"
        ]
      },
      "then": {
        "properties": {
          "files": {
            "contains": {
              "const": "half-map"
            },
            "minContains": 2,
            "maxContains": 2,
            "feedback": {
              "contains": "half-map is required for single, helical, and subtomogram",
              "minContains": "exactly two half-map files are required for single, helical, and subtomogram",
              "maxContains": "exactly two half-map files are required for single, helical, and subtomogram"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "const": "ec"
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "items": {
              "enum": [
                "co-cif",
                "xs-cif",
                "xs-mtz",
                "xa-par",
                "xa-top",
                "xa-mat"
              ],
              "feedback": {
                "enum": "unknown file type for ec"
              }
            },
            "contains": {
              "enum": [
                "xs-cif",
                "xs-mtz"
              ]
            },
            "minContains": 1,
            "maxContains": 1,
            "feedback": {
              "contains": "one reflections file is required for ec",
              "minContains": "only one reflections file is allowed for ec",
              "maxContains": "only one reflections file is allowed for ec"
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "enum": [
              "nmr",
              "ssnmr"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "files": {
            "items": {
              "enum": [
                "co-pdb",
                "co-cif",
                "nm-shi",
                "nm-res-amb",
                "nm-aux-amb",
                "nm-res-ari",
                "nm-res-bio",
                "nm-aux-cha",
                "nm-res-cha",
                "nm-res-cns",
                "nm-res-cya",
                "nm-res-dyn",
                "nm-res-gro",
                "nm-aux-gro",
                "nm-res-isd",
                "nm-res-ros",
                "nm-res-sch",
                "nm-res-syb",
                "nm-res-xpl",
                "nm-res-oth",
                "nm-pea-any",
                "nm-uni-nef",
                "nm-uni-str"
              ],
              "feedback": {
                "enum": "unknown file type for nmr"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "method": {
            "enum": [
              "nmr",
              "ssnmr"
            ]
          }
        }
      },
      "then": {
        "if": {
          "not": {
            "properties": {
              "files": {
                "contains": {
                  "enum": [
                    "nm-uni-nef",
                    "nm-uni-str"
                  ]
                }
              }
            }
          }
        },
        "then": {
          "properties": {
            "files": {
              "allOf": [
                {
                  "contains": {
                    "const": "nm-shi"
                  },
                  "minContains": 1,
                  "maxContains": 1,
                  "feedback": {
                    "contains": "one shifts file is required for nmr",
                    "minContains": "only one shifts file is allowed for nmr",
                    "maxContains": "only one shifts file is allowed for nmr"
                  }
                },
                {
                  "contains": {
                    "enum": [
                      "nm-res-amb",
                      "nm-res-ari",
                      "nm-res-bio",
                      "nm-res-cha",
                      "nm-res-cns",
                      "nm-res-cya",
                      "nm-res-dyn",
                      "nm-res-gro",
                      "nm-res-isd",
                      "nm-res-ros",
                      "nm-res-sch",
                      "nm-res-syb",
                      "nm-res-xpl",
                      "nm-res-oth"
                    ]
                  },
                  "minContains": 1,
                  "feedback": {
                    "contains": "one restraints file is required for nmr"
                  }
                }
              ]
            }
          }
        },
        "else": {
          "properties": {
            "files": {
              "contains": {
                "enum": [
                  "nm-uni-nef",
                  "nm-uni-str"
                ]
              },
              "minContains": 1,
              "maxContains": 1,
              "feedback": {
                "contains": "one unified file is required for nmr",
                "minContains": "only one unified file is allowed for nmr",
                "maxContains": "only one unified file is allowed for nmr"
              }
            }
          }
        }
      }
    }
  ]
}
